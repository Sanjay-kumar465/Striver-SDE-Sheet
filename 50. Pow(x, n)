class Solution {
    public double myPow(double x, int n) {
        //built-in fn
        //double power=Math.pow(x,n);-->> double becuse in the function it is mentioned
        //return power;
        double res=1;
        long exp=n;
        if(exp<0){
            x=1/x;
            exp=-exp;
        }

        while (exp > 0) {
            if (exp % 2 == 1) {
                res *= x;
            }
            x *= x;
            exp /= 2;
        }
        return res;
    }
}
