class Solution {
    public int longestConsecutive(int[] nums) {
        Set<Integer> set = new HashSet<>();
        for(int i=0;i<nums.length;i++) set.add(nums[i]);
        int count = 0;
        int mcount = 0;
        for(int element : set){
            if(!set.contains(element-1)){
                count = 1;
                while(set.contains(element+1)){
                    count++;
                    element++;
                }
                mcount = Math.max(mcount,count);
            }
        }
        return mcount;
    }
}
