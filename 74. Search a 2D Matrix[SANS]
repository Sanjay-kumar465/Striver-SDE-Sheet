class Solution {
    public boolean searchMatrix(int[][] matrix, int target) {
        int r  = matrix.length;
        int c = matrix[0].length;

        int left = 0;
        int right = r * c - 1;

        while(left<=right){
            int mid = left +(right - left)/2;
            int curr = matrix[mid/c][mid % c];

            if(curr == target) return true;
            else if(curr<target) left = mid + 1;
            else right = mid - 1;
        }
        return false;
    }
}
