class Solution {
    public int maxProfit(int[] prices) {
        int ans = 0;
        int max = Integer.MAX_VALUE;
        int temp = 0;

        for(int i=0;i<prices.length;i++){
            if(prices[i]<max){
                max = prices[i];
            }
            temp = prices[i] - max;
            if(ans<temp){
                ans = temp;
            }
        }
        return ans;
    }
}
