class Solution {
    public int majorityElement(int[] nums) {
        int number=nums[0];
        int count=0;
        for(int num :nums){
            if(count==0){
                number=num;
            }
            if(num==number){
                count++;
            }
            else{
                count--;
            }
        }
        return number;
        
    }
}
